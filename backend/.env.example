AWS_REGION=us-east-1
USERS_TABLE=campus_exchange_users
PRODUCTS_TABLE=campus_exchange_products
TUTORS_TABLE=campus_exchange_tutors
# Point this at a DynamoDB Local endpoint (e.g. http://localhost:8000) for offline dev/testing.
# Leave unset to talk to real AWS DynamoDB using your normal AWS credential chain.
DYNAMODB_ENDPOINT_URL=

# openssl rand -hex 32
SECRET_KEY=dev-secret-key-change-me

ACCESS_TOKEN_EXPIRE_MINUTES=1440
REMEMBER_ME_EXPIRE_MINUTES=43200

CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
COOKIE_SECURE=false
